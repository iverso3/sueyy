/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

/* 容器 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn {
  border-radius: 50rpx;
  text-align: center;
  padding: 20rpx 0;
  font-weight: 500;
  font-size: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  color: white;
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

/* 输入框 */
.input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.input:focus {
  border-color: #ff6b35;
}

/* 标题 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 16rpx;
}

/* 商品项 */
.menu-item {
  display: flex;
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.menu-item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.menu-item-info {
  flex: 1;
}

.menu-item-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #333;
}

.menu-item-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.menu-item-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b35;
}

/* 加载更多 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}