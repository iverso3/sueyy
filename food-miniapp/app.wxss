/* 全局样式 - 橙色主题餐饮小程序设计系统 */
@import './styles/global.wxss';

page {
  background-color: #F8FAFC;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  /* 橙色主题色变量 */
  --primary-color: #F97316;
  --primary-gradient: linear-gradient(135deg, #F97316, #FB923C);
  --primary-light: #FFEDD5;
  --primary-dark: #EA580C;

  --secondary-color: #2563EB;
  --background-color: #F8FAFC;
  --surface-color: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border-color: #E2E8F0;
  --divider-color: #F1F5F9;
  --success-color: #10B981;
  --warning-color: #F59E0B;
  --error-color: #EF4444;
  --shadow-sm: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 9999rpx;
}

/* 容器 */
.container {
  min-height: 100vh;
  background-color: var(--background-color);
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-md);
}

/* 按钮样式 */
.btn {
  border-radius: var(--radius-full);
  text-align: center;
  padding: 20rpx 0;
  font-weight: 500;
  font-size: 32rpx;
  transition: all 0.2s ease;
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-primary {
  background: var(--primary-gradient);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.3);
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

/* 输入框 */
.input {
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  background-color: var(--surface-color);
  transition: all 0.2s;
}

.input:focus {
  border-color: var(--primary-color);
}

.input::placeholder {
  color: var(--text-tertiary);
}

/* 标题 */
.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: var(--text-primary);
}

.subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* 商品项 */
.menu-item {
  display: flex;
  padding: 20rpx;
  background: var(--surface-color);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.menu-item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.menu-item-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  color: var(--text-primary);
  line-height: 1.3;
}

.menu-item-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.menu-item-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* 加载更多 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-state image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state .empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

/* 价格样式 */
.price {
  color: var(--primary-color);
  font-weight: 700;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--divider-color);
  margin: 0 30rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  border-radius: var(--radius-sm);
  background-color: var(--primary-light);
  color: var(--primary-dark);
}

.tag-hot {
  background-color: #FEE2E2;
  color: #DC2626;
}

.tag-new {
  background-color: #DCFCE7;
  color: #16A34A;
}
