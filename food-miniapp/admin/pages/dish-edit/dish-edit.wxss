/* pages/dish-edit/dish-edit.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.form {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.form-section {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.required {
  color: #f44336;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
}

.currency {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.price-input {
  flex: 1;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.picker .arrow {
  color: #999;
  font-size: 24rpx;
}

/* 图片上传 */
.image-upload-section {
  display: flex;
  flex-direction: column;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx dashed #ddd;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 24rpx;
}

.upload-placeholder .icon {
  font-size: 60rpx;
  line-height: 1;
}

.image-actions {
  display: flex;
  margin-top: 16rpx;
}

.image-action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background-color: #2196f3;
  color: #fff;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.image-action-btn.remove {
  background-color: #f44336;
}

/* 开关 */
.switches {
  display: flex;
  flex-direction: column;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.switch-item:last-child {
  border-bottom: none;
}

.switch-label {
  font-size: 28rpx;
  color: #333;
}

/* 提交按钮 */
.submit-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #4caf50;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 规格管理 */
.spec-list {
  margin-bottom: 20rpx;
}

.spec-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.spec-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.spec-name {
  font-size: 28rpx;
  color: #333;
}

.spec-price {
  font-size: 24rpx;
  color: #ff9800;
  margin-left: 16rpx;
}

.spec-default {
  font-size: 22rpx;
  color: #4caf50;
  background-color: #e8f5e9;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
}

.spec-actions {
  display: flex;
}

.spec-action-btn {
  font-size: 24rpx;
  color: #2196f3;
  padding: 8rpx 16rpx;
}

.spec-action-btn.delete {
  color: #f44336;
}

.spec-empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx;
}

.add-spec-btn {
  text-align: center;
  padding: 20rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  color: #2196f3;
  font-size: 28rpx;
}

.field-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  max-height: 80vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-cancel-btn {
  flex: 1;
  height: 80rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-confirm-btn {
  flex: 1;
  height: 80rpx;
  background-color: #4caf50;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
