/* pages/order/order.wxss - 橙色主题 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--background-color);
}

/* 顶部标题栏 - 橙色 */
.header {
  background: linear-gradient(135deg, #EA580C, #F97316, #FB923C);
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.2);
  flex-shrink: 0;
}

.header-title {
  display: block;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* 订单列表区域 */
.orders-scroll {
  flex: 1;
  background-color: var(--background-color);
}

.orders-list {
  padding: 24rpx;
}

/* 日期分组标题 */
.date-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 12rpx;
  margin-bottom: 16rpx;
}

.date-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 用户分组标题 */
.user-group {
  padding: 20rpx 12rpx;
  background-color: #FFF7ED;
  margin: 16rpx 0;
  border-radius: 12rpx;
  border-left: 6rpx solid #F97316;
}

.user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #EA580C;
}

.group-arrow {
  font-size: 28rpx;
  color: #94A3B8;
  transition: transform 0.3s;
}

.group-arrow.expanded {
  transform: rotate(90deg);
}

/* 订单卡片 */
.order-card {
  background-color: var(--surface-color);
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  overflow: hidden;
  transition: all 0.2s ease;
}

.order-card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.store-info {
  display: flex;
  align-items: center;
}

.store-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 14rpx;
  background-color: #FFF7ED;
}

.store-avatar image {
  width: 100%;
  height: 100%;
}

.store-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.arrow-icon {
  font-size: 26rpx;
  color: #94A3B8;
  margin-left: 10rpx;
}

.order-status {
  font-size: 28rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.order-status.PROCESSING, .order-status.processing {
  color: #EA580C;
  background-color: #FFEDD5;
}

.order-status.COMPLETED, .order-status.completed {
  color: #059669;
  background-color: #D1FAE5;
}

.order-status.CANCELLED, .order-status.cancelled {
  color: #94A3B8;
  background-color: #F1F5F9;
}

/* 订单内容 */
.order-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
}

.items-info {
  flex: 1;
}

.items-name {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.items-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
  gap: 14rpx;
}

.dish-tag {
  font-size: 24rpx;
  color: #92400E;
  background-color: #FEF3C7;
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
}

.order-price {
  flex-shrink: 0;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* 订单底部 */
.order-footer {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-top: 1rpx solid var(--divider-color);
}

.order-time {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 加载状态 */
.loading, .no-more {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  text-align: center;
}

.empty-order image {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 48rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-tertiary);
  margin-bottom: 48rpx;
}

.go-to-menu {
  padding: 24rpx 70rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  transition: all 0.2s ease;
}

.go-to-menu:active {
  transform: scale(0.98);
}
