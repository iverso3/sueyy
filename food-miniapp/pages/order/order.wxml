<!--pages/order/order.wxml-->
<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <text class="header-title">我的订单</text>
  </view>

  <!-- 订单列表（按时间分组） -->
  <scroll-view class="orders-scroll" scroll-y="true">
    <view class="orders-list">
      <!-- 日期分组 -->
      <block wx:for="{{groupedOrders}}" wx:key="date">
        <!-- 分组标题（日期+箭头） -->
        <view class="date-group" bindtap="toggleGroup" data-index="{{index}}">
          <text class="date-label">{{item.date}}</text>
          <text class="group-arrow {{item.expanded ? 'expanded' : ''}}">></text>
        </view>

        <!-- 订单卡片列表 -->
        <view wx:if="{{item.expanded}}" class="group-orders">
          <!-- 管理员模式：按用户分组显示 -->
          <block wx:if="{{item.userGroups}}">
            <block wx:for="{{item.userGroups}}" wx:key="userName" wx:for-item="userGroup">
              <!-- 用户分组标题 -->
              <view class="user-group">
                <text class="user-name">👤 {{userGroup.userName}}</text>
              </view>
              <!-- 用户下的订单 -->
              <block wx:for="{{userGroup.orders}}" wx:key="id">
                <view class="order-card" bindtap="goToOrderDetail" data-id="{{item.id}}">
                  <view class="order-header">
                    <view class="store-info">
                      <image class="store-avatar" src="{{item.storeLogo || '/images/default-avatar.png'}}" mode="aspectFill" />
                      <text class="store-name">{{item.storeName || '家庭厨房'}}</text>
                      <text class="arrow-icon">></text>
                    </view>
                    <text class="order-status {{item.status}}">{{item.statusText}}</text>
                  </view>

                  <view class="order-content">
                    <view class="items-info">
                      <text class="items-name">{{item.itemsText}}</text>
                      <view class="items-list" wx:if="{{item.itemList && item.itemList.length > 0}}">
                        <text wx:for="{{item.itemList}}" wx:key="index" wx:for-item="dishName" class="dish-tag">{{dishName}}</text>
                      </view>
                    </view>
                    <view class="order-price">
                      <text class="price-value">¥{{item.actualAmount}}</text>
                    </view>
                  </view>

                  <view class="order-footer">
                    <text class="order-time">{{item.createdAt}}</text>
                  </view>
                </view>
              </block>
            </block>
          </block>

          <!-- 普通用户模式：直接显示订单 -->
          <block wx:else>
            <block wx:for="{{item.orders}}" wx:key="id">
              <view class="order-card" bindtap="goToOrderDetail" data-id="{{item.id}}">
                <view class="order-header">
                  <view class="store-info">
                    <image class="store-avatar" src="{{item.storeLogo || '/images/default-avatar.png'}}" mode="aspectFill" />
                    <text class="store-name">{{item.storeName || '家庭厨房'}}</text>
                    <text class="arrow-icon">></text>
                  </view>
                  <text class="order-status {{item.status}}">{{item.statusText}}</text>
                </view>

                <view class="order-content">
                  <view class="items-info">
                    <text class="items-name">{{item.itemsText}}</text>
                    <view class="items-list" wx:if="{{item.itemList && item.itemList.length > 0}}">
                      <text wx:for="{{item.itemList}}" wx:key="index" wx:for-item="dishName" class="dish-tag">{{dishName}}</text>
                    </view>
                  </view>
                  <view class="order-price">
                    <text class="price-value">¥{{item.actualAmount}}</text>
                  </view>
                </view>

                <view class="order-footer">
                  <text class="order-time">{{item.createdAt}}</text>
                </view>
              </view>
            </block>
          </block>
        </view>
      </block>

      <!-- 空状态 -->
      <view wx:if="{{orders.length === 0 && !loading}}" class="empty-order">
        <image src="/images/empty-cart.png" mode="aspectFit" />
        <text class="empty-text">暂无订单，快去下单吧</text>
        <view class="go-to-menu" bindtap="goToMenu">
          <text>去点餐</text>
        </view>
      </view>

      <!-- 加载状态 -->
      <view wx:if="{{loading}}" class="loading">
        <text>加载中...</text>
      </view>
    </view>
  </scroll-view>
</view>
