/* pages/cart/cart.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
  padding-bottom: 120rpx;
}

/* 购物车头部 */
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-left {
  display: flex;
  align-items: center;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background-color: #ff6b35;
  border-color: #ff6b35;
  position: relative;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 18rpx;
  border: 3rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg) translate(-2rpx, -2rpx);
}

.select-all-text {
  font-size: 26rpx;
  color: #666;
}

.cart-header .title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  text-align: center;
}

.header-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.action-btn image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

/* 购物车列表 */
.cart-list {
  flex: 1;
  padding: 0 30rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin: 0 25rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.3;
}

.item-price {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.current-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6b35;
  margin-right: 20rpx;
}

.subtotal {
  font-size: 26rpx;
  color: #999;
}

/* 数量调整 */
.quantity-control {
  display: flex;
  align-items: center;
  width: 200rpx;
}

.quantity-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quantity-btn image {
  width: 24rpx;
  height: 24rpx;
}

.quantity {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 25rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn image {
  width: 30rpx;
  height: 30rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  text-align: center;
}

.empty-cart image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.go-to-menu {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: #999;
}

/* 购物车底部 */
.cart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.footer-left {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 15rpx;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6b35;
  margin-right: 20rpx;
}

.total-quantity {
  font-size: 24rpx;
  color: #999;
}

.footer-right {
  flex-shrink: 0;
}

.checkout-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  min-width: 180rpx;
}

.checkout-btn.delete-mode {
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
}

.checkout-btn.disabled {
  background: linear-gradient(135deg, #ccc, #ddd);
}

/* 选中信息 */
.selected-info {
  display: flex;
  align-items: baseline;
}

.selected-count {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}

.selected-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6b35;
}

/* 响应式调整 */
@media (min-width: 768px) {
  .container {
    max-width: 750px;
    margin: 0 auto;
  }
}