/* pages/menu/menu.wxss - 橙色主题 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--background-color);
}

/* 顶部区域 - 橙色背景 */
.header {
  background: linear-gradient(135deg, #EA580C, #F97316, #FB923C);
  padding: 20rpx 30rpx 40rpx;
  flex-shrink: 0;
}

.header-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-icon {
  font-size: 40rpx;
  color: #ffffff;
}

.header-center {
  flex: 1;
  margin-left: 20rpx;
}

.store-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.store-welcome {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
  background: transparent;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.75);
}

/* 主内容区 - 左右分栏 */
.main-content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* 左侧分类导航 */
.category-sidebar {
  width: 180rpx;
  background-color: #FFFFFF;
  flex-shrink: 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  font-size: 24rpx;
  color: #6B7280;
  position: relative;
  transition: all 0.2s ease;
}

.category-item:active {
  background-color: rgba(249, 115, 22, 0.08);
}

.category-item.active {
  background-color: #FEF3C7;
  color: #D97706;
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: #D97706;
  border-radius: 0 4rpx 4rpx 0;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  text-align: center;
  line-height: 1.2;
}

/* 右侧菜品列表 */
.menu-scroll {
  flex: 1;
  background-color: var(--background-color);
}

.menu-list {
  padding: 24rpx;
}

.menu-item {
  display: flex;
  background-color: var(--surface-color);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.menu-item:active {
  box-shadow: var(--shadow-md);
  transform: translateY(2rpx);
}

/* 菜品图片区域 */
.item-image-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-tag {
  position: absolute;
  left: 0;
  top: 0;
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, #EF4444, #F87171);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 8rpx 0 8rpx 0;
}

/* 菜品信息 */
.item-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.item-description {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  min-height: 50rpx;
}

.item-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* 添加按钮容器 */
.item-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 添加按钮 */
.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.4);
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.3);
}

/* 加载状态 */
.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.empty-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

/* 悬浮购物车按钮 */
.float-cart {
  position: fixed;
  bottom: 140rpx;
  right: 30rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(249, 115, 22, 0.45);
  z-index: 99;
  transition: all 0.2s ease;
}

.float-cart:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.35);
}

.cart-icon {
  font-size: 48rpx;
}

.cart-icon-img {
  width: 54rpx;
  height: 54rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #EF4444;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  min-width: 36rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.4);
}

/* 规格选择弹窗 */
/* 规格选择弹窗 */
.spec-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(30, 20, 10, 0.45);
  z-index: 1000;
  backdrop-filter: blur(4rpx);
  -webkit-backdrop-filter: blur(4rpx);
}

.spec-picker-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 560rpx;
  background: #FFFBF5;
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(180, 90, 20, 0.12);
  animation: specSlideUp 0.38s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes specSlideUp {
  from {
    transform: translateY(100%);
    opacity: 0.6;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* 拖动指示条 */
.spec-picker-handle {
  width: 80rpx;
  height: 6rpx;
  background: #E8DDD4;
  border-radius: 3rpx;
  margin: 16rpx auto 0;
}

.spec-picker-close-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 44rpx;
  color: #C4A99A;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  border-radius: 50%;
  background: rgba(200, 180, 160, 0.12);
}

.spec-picker-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 180rpx;
  display: flex;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #F0E8E0;
  box-sizing: border-box;
  align-items: center;
}

.spec-picker-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(120, 60, 10, 0.18);
}

.spec-picker-info {
  margin-left: 28rpx;
  flex: 1;
}

.spec-picker-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #3D2B1F;
  letter-spacing: 1rpx;
}

.spec-picker-price {
  font-size: 44rpx;
  font-weight: 800;
  color: #D4530A;
  margin-top: 10rpx;
  letter-spacing: -0.5rpx;
}

.spec-picker-section {
  position: absolute;
  top: 180rpx;
  left: 0;
  right: 0;
  bottom: 120rpx;
  overflow-y: auto;
}

.spec-section-title {
  font-size: 26rpx;
  color: #B0947E;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 24rpx;
  display: block;
  padding: 20rpx 32rpx 0;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  padding: 0 32rpx 20rpx;
}

.spec-item {
  padding: 18rpx 36rpx;
  background: #FFF8F0;
  border-radius: 100rpx;
  border: 2rpx solid #EFE4D8;
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.spec-item-name {
  font-size: 28rpx;
  color: #5C3D2E;
  font-weight: 500;
}

.spec-item-price {
  font-size: 24rpx;
  color: #C4874A;
  font-weight: 600;
}

.spec-item-active {
  background: #FFF0E0;
  border-color: #D4530A;
  box-shadow: 0 4rpx 12rpx rgba(212, 83, 10, 0.15);
}

.spec-item-active .spec-item-name {
  color: #D4530A;
  font-weight: 700;
}

.spec-item-active .spec-item-price {
  color: #D4530A;
}

.spec-picker-btns {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #FFFBF5 80%, rgba(255, 251, 245, 0));
  box-sizing: border-box;
}

.spec-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #E8670A 0%, #FF9A3C 100%);
  box-shadow: 0 6rpx 24rpx rgba(232, 103, 10, 0.35);
  letter-spacing: 3rpx;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.spec-btn:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(232, 103, 10, 0.25);
}
