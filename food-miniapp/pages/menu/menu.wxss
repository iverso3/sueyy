/* pages/menu/menu.wxss - 橙色主题 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--background-color);
}

/* 顶部区域 - 橙色背景 */
.header {
  background: linear-gradient(135deg, #EA580C, #F97316, #FB923C);
  padding: 20rpx 30rpx 40rpx;
  flex-shrink: 0;
}

.header-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-icon {
  font-size: 40rpx;
  color: #ffffff;
}

.header-center {
  flex: 1;
  margin-left: 20rpx;
}

.store-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.store-welcome {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
  background: transparent;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.75);
}

/* 主内容区 - 左右分栏 */
.main-content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* 左侧分类导航 */
.category-sidebar {
  width: 180rpx;
  background-color: #FFFFFF;
  flex-shrink: 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  font-size: 24rpx;
  color: #6B7280;
  position: relative;
  transition: all 0.2s ease;
}

.category-item:active {
  background-color: rgba(249, 115, 22, 0.08);
}

.category-item.active {
  background-color: #FEF3C7;
  color: #D97706;
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: #D97706;
  border-radius: 0 4rpx 4rpx 0;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  text-align: center;
  line-height: 1.2;
}

/* 右侧菜品列表 */
.menu-scroll {
  flex: 1;
  background-color: var(--background-color);
}

.menu-list {
  padding: 24rpx;
}

.menu-item {
  display: flex;
  background-color: var(--surface-color);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.menu-item:active {
  box-shadow: var(--shadow-md);
  transform: translateY(2rpx);
}

/* 菜品图片区域 */
.item-image-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-tag {
  position: absolute;
  left: 0;
  top: 0;
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, #EF4444, #F87171);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 8rpx 0 8rpx 0;
}

/* 菜品信息 */
.item-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.item-description {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  min-height: 50rpx;
}

.item-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* 添加按钮 */
.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.4);
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.3);
}

/* 加载状态 */
.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.empty-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

/* 悬浮购物车按钮 */
.float-cart {
  position: fixed;
  bottom: 140rpx;
  right: 30rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(249, 115, 22, 0.45);
  z-index: 99;
  transition: all 0.2s ease;
}

.float-cart:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.35);
}

.cart-icon {
  font-size: 48rpx;
}

.cart-icon-img {
  width: 54rpx;
  height: 54rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #EF4444;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  min-width: 36rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.4);
}
