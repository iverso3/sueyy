/* pages/menu-management/menu-management.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.search-bar {
  padding: 20rpx;
  background-color: #fff;
}

.search-input-wrap {
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 15rpx 30rpx;
}

.search-input {
  font-size: 28rpx;
}

.category-filter {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.category-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.category-picker .arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 10rpx;
}

.dish-list {
  height: calc(100vh - 200rpx);
  padding: 20rpx;
}

.dish-item {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  position: relative;
  overflow: hidden;
}

.dish-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.dish-image image {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #999;
}

.dish-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.dish-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.dish-status.active {
  background-color: #e8f5e9;
  color: #4caf50;
}

.dish-status.inactive {
  background-color: #ffebee;
  color: #f44336;
}

.dish-category {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.dish-footer {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.dish-price {
  font-size: 32rpx;
  color: #f44336;
  font-weight: bold;
}

.dish-original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.dish-tags {
  display: flex;
  margin-left: auto;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}

.tag.recommended {
  background-color: #fff3e0;
  color: #ff9800;
}

.tag.hot {
  background-color: #ffebee;
  color: #f44336;
}

.dish-actions {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  margin-left: 10rpx;
}

.action-btn.edit {
  background-color: #2196f3;
  color: #fff;
}

.action-btn.delete {
  background-color: #f44336;
  color: #fff;
}

.loading-status,
.no-more,
.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 88rpx;
  background-color: #4caf50;
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.4);
}
