/* pages/upload/upload.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 标题 */
.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

/* 区块 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 选择器 */
.picker {
  width: 100%;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #fafafa;
}

.picker-text {
  font-size: 32rpx;
  color: #333;
}

.picker-placeholder {
  font-size: 32rpx;
  color: #999;
}

.picker-arrow {
  font-size: 28rpx;
  color: #999;
}

/* 图片选择 */
.image-section {
  margin-bottom: 30rpx;
}

.image-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 20rpx;
  text-align: center;
}

.preview-text {
  color: #fff;
  font-size: 28rpx;
}

.image-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 400rpx;
  border: 4rpx dashed #e0e0e0;
  border-radius: 16rpx;
  background-color: #fafafa;
  margin-bottom: 20rpx;
}

.upload-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

.choose-btn {
  width: 100%;
  padding: 24rpx;
  text-align: center;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333;
}

.choose-btn:active {
  background-color: #e0e0e0;
}

/* 上传按钮 */
.upload-btn {
  width: 100%;
  padding: 28rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.upload-btn.disabled {
  background-color: #cccccc;
  color: #999;
}

.upload-btn:not(.disabled):active {
  background-color: #06ad56;
}

/* 结果区域 */
.result-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.result-success {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #e8f5e9;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.result-error {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #ffebee;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.result-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.result-message {
  font-size: 28rpx;
  color: #333;
}

/* 图片URL */
.image-url-section {
  margin-top: 20rpx;
}

.url-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.url-container {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.url-text {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
}

.copy-btn {
  padding: 12rpx 24rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.copy-btn:active {
  background-color: #06ad56;
}

/* 新图片预览 */
.new-image-preview {
  margin-top: 20rpx;
}

.preview-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.new-image {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
}

/* 清除按钮 */
.clear-section {
  margin-top: 40rpx;
}

.clear-btn {
  width: 100%;
  padding: 24rpx;
  background-color: #f0f0f0;
  color: #333;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.clear-btn:active {
  background-color: #e0e0e0;
}

/* 使用说明 */
.instructions {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.instructions-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.instruction-item {
  margin-bottom: 15rpx;
  padding-left: 20rpx;
  position: relative;
}

.instruction-item:before {
  content: "•";
  position: absolute;
  left: 0;
  color: #07c160;
  font-size: 32rpx;
}

.instruction-item text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}