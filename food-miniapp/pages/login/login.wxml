<!--pages/login/login.wxml-->
<view class="container">
  <view class="card" style="margin-top: 200rpx; text-align: center;">
    <view class="logo-container">
      <text class="logo-emoji">🍜</text>
    </view>
    <text class="title">在线点餐</text>
    <text class="subtitle" style="display: block; margin-top: 20rpx; margin-bottom: 60rpx;">
      美味佳肴，触手可及
    </text>

    <button
      class="btn btn-primary"
      style="margin-bottom: 30rpx;"
      bindtap="handleWeChatLogin"
      loading="{{isLoading}}"
      disabled="{{isLoading}}"
    >
      微信一键登录
    </button>

    <button
      class="btn btn-secondary"
      style="margin-bottom: 30rpx;"
      bindtap="handleMockLogin"
      hidden="{{!useMockData}}"
    >
      模拟登录（测试）
    </button>

    <text class="subtitle" style="font-size: 24rpx; color: #999; display: block; margin-top: 40rpx;">
      登录即代表同意《用户协议》和《隐私政策》
    </text>

    <!-- 错误提示 -->
    <view wx:if="{{errorMsg}}" style="margin-top: 30rpx; padding: 20rpx; background: #fff2f2; border-radius: 12rpx; text-align: left;">
      <text style="color: #ff4d4f; font-size: 26rpx;">{{errorMsg}}</text>
    </view>
  </view>

  <!-- 功能说明 -->
  <view class="card" style="margin-top: 60rpx;">
    <text class="subtitle" style="font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 30rpx;">
      功能特色
    </text>

    <view style="display: flex; align-items: flex-start; margin-bottom: 25rpx;">
      <text class="feature-icon">🍽️</text>
      <view style="flex: 1;">
        <text style="font-size: 28rpx; font-weight: 500; display: block;">丰富菜品</text>
        <text style="font-size: 26rpx; color: #999; margin-top: 5rpx;">上百种美味菜品任您挑选</text>
      </view>
    </view>

    <view style="display: flex; align-items: flex-start; margin-bottom: 25rpx;">
      <text class="feature-icon">🛒</text>
      <view style="flex: 1;">
        <text style="font-size: 28rpx; font-weight: 500; display: block;">便捷购物车</text>
        <text style="font-size: 26rpx; color: #999; margin-top: 5rpx;">随时添加修改购物车商品</text>
      </view>
    </view>

    <view style="display: flex; align-items: flex-start;">
      <text class="feature-icon">💳</text>
      <view style="flex: 1;">
        <text style="font-size: 28rpx; font-weight: 500; display: block;">安全支付</text>
        <text style="font-size: 26rpx; color: #999; margin-top: 5rpx;">微信支付保障交易安全</text>
      </view>
    </view>
  </view>
</view>