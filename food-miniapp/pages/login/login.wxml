<!--pages/login/login.wxml-->
<view class="container">
  <!-- 阳光光晕 -->
  <view class="sun-glow"></view>

  <!-- 飘落光点 -->
  <view class="particles">
    <view class="particle"></view>
    <view class="particle"></view>
    <view class="particle"></view>
    <view class="particle"></view>
    <view class="particle"></view>
  </view>

  <view class="main-content">
    <!-- Logo区域 -->
    <view class="logo-section">
      <view class="logo-badge">
        <image class="logo-gif" src="/images/logo.gif" mode="aspectFit" />
      </view>
      <view class="brand-text">
        <view class="brand-name">家庭餐厅</view>
        <view class="brand-slogan">爱你每一天 · 暖心暖胃</view>
      </view>
    </view>

    <!-- 登录卡片 -->
    <view class="login-card">
      <button
        class="btn-wechat"
        bindtap="handleWeChatLogin"
        loading="{{isLoading}}"
        disabled="{{isLoading}}"
      >
        <text class="btn-icon">☀️</text>
        <text>微信一键登录</text>
      </button>

      <view class="agreement">
        登录即表示同意 <text>《用户协议》</text> 和 <text>《隐私政策》</text>
      </view>
    </view>

    <!-- 特色展示 -->
    <view class="features">
      <view class="features-title">🌟 精选美食，快捷送达</view>
      <view class="features-row">
        <view class="feature-pill">
          <text>🍽️</text>
          <text>招牌菜品</text>
        </view>
        <view class="feature-pill">
          <text>🚚</text>
          <text>闪电配送</text>
        </view>
        <view class="feature-pill">
          <text>🎁</text>
          <text>新人专享</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="bottom-decor"></view>

  <!-- 错误提示 -->
  <view wx:if="{{errorMsg}}" class="error-toast">
    {{errorMsg}}
  </view>
</view>
