/* pages/login/login.wxss - 阳光温暖治愈风 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9E6 0%, #FFEFD5 40%, #FFE4B5 100%);
  position: relative;
  overflow: hidden;
}

/* 阳光光晕效果 */
.sun-glow {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 200, 100, 0.6) 0%, rgba(255, 180, 80, 0.3) 30%, transparent 70%);
  border-radius: 50%;
  animation: sunPulse 4s ease-in-out infinite;
}

/* 飘落的花瓣/光点 */
.particles {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  pointer-events: none;
}

.particle {
  position: absolute;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  animation: fall linear infinite;
}

.particle:nth-child(1) {
  width: 12rpx;
  height: 12rpx;
  left: 10%;
  animation-duration: 8s;
  animation-delay: 0s;
}

.particle:nth-child(2) {
  width: 8rpx;
  height: 8rpx;
  left: 25%;
  animation-duration: 10s;
  animation-delay: 2s;
}

.particle:nth-child(3) {
  width: 16rpx;
  height: 16rpx;
  left: 45%;
  animation-duration: 9s;
  animation-delay: 1s;
}

.particle:nth-child(4) {
  width: 10rpx;
  height: 10rpx;
  left: 70%;
  animation-duration: 11s;
  animation-delay: 3s;
}

.particle:nth-child(5) {
  width: 14rpx;
  height: 14rpx;
  left: 85%;
  animation-duration: 7s;
  animation-delay: 0.5s;
}

/* 主内容 */
.main-content {
  position: relative;
  z-index: 1;
  padding: 100rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  animation: bounceIn 0.8s ease-out;
}

.logo-badge {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.logo-circle {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(145deg, #FFD700 0%, #FFA500 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 16rpx 48rpx rgba(255, 165, 0, 0.35),
    0 8rpx 24rpx rgba(255, 140, 0, 0.2),
    inset 0 -8rpx 24rpx rgba(0, 0, 0, 0.1),
    inset 0 8rpx 16rpx rgba(255, 255, 255, 0.4);
  position: relative;
}

.logo-circle.cute {
  background: linear-gradient(145deg, #FFB6C1 0%, #FF69B4 50%, #FF1493 100%);
  box-shadow:
    0 16rpx 48rpx rgba(255, 105, 180, 0.4),
    0 8rpx 24rpx rgba(255, 20, 147, 0.2),
    inset 0 -8rpx 24rpx rgba(0, 0, 0, 0.1),
    inset 0 8rpx 16rpx rgba(255, 255, 255, 0.4);
  animation: cuteBounce 2s ease-in-out infinite;
}

.logo-circle.cute .logo-emoji {
  font-size: 100rpx;
}

/* Logo GIF */
.logo-gif {
  width: 180rpx;
  height: 180rpx;
  border-radius: 40rpx;
}

@keyframes cuteBounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.logo-circle::after {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 24rpx;
  width: 60rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  transform: rotate(-30deg);
}

.logo-emoji {
  font-size: 100rpx;
  line-height: 1;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.15));
}

.brand-text {
  text-align: center;
}

.brand-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #5D4037;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
  text-shadow: 2rpx 2rpx 0 rgba(255, 255, 255, 0.8);
}

.brand-slogan {
  font-size: 28rpx;
  color: #8D6E63;
  letter-spacing: 8rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  border-radius: 40rpx;
  padding: 56rpx 40rpx;
  box-shadow:
    0 12rpx 40rpx rgba(139, 90, 43, 0.15),
    0 4rpx 12rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  animation: slideUp 0.6s ease-out 0.2s both;
  margin-bottom: 48rpx;
}

/* 登录按钮 */
.btn-wechat {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #52C41A 0%, #73D13D 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 12rpx 32rpx rgba(82, 196, 26, 0.35),
    0 4rpx 12rpx rgba(82, 196, 26, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2);
  border: none;
  position: relative;
  overflow: hidden;
}

.btn-wechat::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shine 2s ease-in-out infinite;
}

.btn-wechat:active {
  transform: scale(0.96);
  box-shadow:
    0 6rpx 16rpx rgba(82, 196, 26, 0.25),
    inset 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.btn-wechat text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

.btn-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
  white-space: nowrap;
}

/* 协议 */
.agreement {
  text-align: center;
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #A1887F;
}

.agreement text {
  color: #FF8C00;
  font-weight: 500;
}

/* 特色展示 */
.features {
  width: 100%;
  animation: slideUp 0.6s ease-out 0.4s both;
}

.features-title {
  text-align: center;
  font-size: 26rpx;
  color: #8D6E63;
  letter-spacing: 4rpx;
  margin-bottom: 36rpx;
}

.features-row {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  flex-wrap: wrap;
}

.feature-pill {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 90, 43, 0.1);
}

.feature-pill text:first-child {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.feature-pill text:last-child {
  font-size: 26rpx;
  color: #6D4C41;
  font-weight: 500;
}

/* 底部装饰 */
.bottom-decor {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120"><path fill="%23FFE4B5" d="M0,64L80,69.3C160,75,320,85,480,80C640,75,800,53,960,48C1120,43,1280,53,1360,58.7L1440,64L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z"></path></svg>') no-repeat bottom;
  background-size: 100% 100%;
}

/* 错误提示 */
.error-toast {
  position: fixed;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255, 87, 34, 0.95);
  color: #FFFFFF;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.3);
  z-index: 100;
  animation: fadeIn 0.3s ease-out;
}

/* 动画 */
@keyframes sunPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.1);
    opacity: 1;
  }
}

@keyframes fall {
  0% {
    transform: translateY(-20rpx) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(360deg);
    opacity: 0;
  }
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.5);
  }
  60% {
    transform: scale(1.08);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes shine {
  0% {
    left: -100%;
  }
  50%, 100% {
    left: 100%;
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 响应式 */
@media (min-width: 768px) {
  .main-content {
    max-width: 500rpx;
    margin: 0 auto;
    padding: 80rpx 0;
  }
}
