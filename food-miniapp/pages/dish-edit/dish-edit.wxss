/* pages/dish-edit/dish-edit.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.form {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.form-section {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.required {
  color: #f44336;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
}

.currency {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.price-input {
  flex: 1;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.picker .arrow {
  color: #999;
  font-size: 24rpx;
}

/* 图片上传 */
.image-upload {
  width: 200rpx;
  height: 200rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 24rpx;
}

.upload-placeholder .icon {
  font-size: 60rpx;
  line-height: 1;
}

.image-actions {
  display: flex;
  margin-top: 16rpx;
}

.image-action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background-color: #2196f3;
  color: #fff;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.image-action-btn.remove {
  background-color: #f44336;
}

/* 开关 */
.switches {
  display: flex;
  flex-direction: column;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.switch-item:last-child {
  border-bottom: none;
}

.switch-label {
  font-size: 28rpx;
  color: #333;
}

/* 提交按钮 */
.submit-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #4caf50;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
