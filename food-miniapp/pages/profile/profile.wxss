/* pages/profile/profile.wxss - 橙色主题 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--background-color);
}

/* 顶部用户信息区域 - 橙色 */
.header {
  background: linear-gradient(135deg, #EA580C, #F97316, #FB923C);
  padding: 80rpx 30rpx 60rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-right: 28rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 70rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.vip-level {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  display: inline-block;
  font-weight: 500;
}

/* 功能列表 */
.menu-list {
  background-color: var(--surface-color);
  margin-top: -20rpx;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  padding-top: 20rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid var(--divider-color);
  transition: background-color 0.2s ease;
}

.menu-item:active {
  background-color: #FFF7ED;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 28rpx;
}

.menu-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.arrow {
  font-size: 30rpx;
  color: #CBD5E1;
}
