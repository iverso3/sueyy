<!--pages/order-detail/order-detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 订单内容 -->
  <view wx:if="{{!loading && order}}" class="order-content">
    <!-- 订单状态 -->
    <view class="order-status">
      <text class="status-text">{{order.status === 'PLACED' ? '已下单' : order.status === 'COMPLETED' ? '已制作完成' : order.status}}</text>
    </view>

    <!-- 管理员状态修改按钮 -->
    <view wx:if="{{isAdmin}}" class="admin-status-btn" bindtap="changeOrderStatus">
      <text>修改状态</text>
    </view>

    <!-- 订单信息 -->
    <view class="order-info">
      <view class="info-row">
        <text class="label">订单号</text>
        <text class="value">{{order.orderNo}}</text>
      </view>
      <view wx:if="{{isAdmin}}" class="info-row">
        <text class="label">下单人</text>
        <text class="value">{{order.userNickname || order.userId}}</text>
      </view>
      <view class="info-row">
        <text class="label">下单时间</text>
        <text class="value">{{order.createdAt}}</text>
      </view>
      <view class="info-row">
        <text class="label">取餐时间</text>
        <text class="value">{{order.pickupTime}}</text>
      </view>
    </view>

    <!-- 菜品列表 -->
    <view class="order-items">
      <text class="section-title">菜品明细</text>
      <view wx:for="{{order.items}}" wx:key="id" class="item">
        <image class="item-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="item-info">
          <view class="item-name-row">
            <text class="item-name">{{item.menuItemName}}</text>
            <!-- 删除菜品按钮 -->
            <view wx:if="{{canEdit}}" class="delete-item-btn" bindtap="deleteOrderItem" data-id="{{item.id}}">
              <text>删除</text>
            </view>
          </view>
          <view class="item-price">
            <text class="price">¥{{item.price}} × {{item.quantity}}</text>
            <text class="subtotal">¥{{item.subtotal}}</text>
          </view>
          <!-- 评价显示（订单完成后） -->
          <view wx:if="{{order.status === 'COMPLETED' && item.hasReviewed}}" class="item-review">
            <text class="review-stars">{{item.rating}}星</text>
            <text wx:if="{{item.comment}}" class="review-comment">{{item.comment}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单金额 -->
    <view class="order-amount">
      <view class="amount-row">
        <text class="label">菜品总价</text>
        <text class="value">¥{{order.totalAmount}}</text>
      </view>
      <view class="amount-row">
        <text class="label">优惠金额</text>
        <text class="value">-¥{{order.discountAmount}}</text>
      </view>
      <view class="amount-row total">
        <text class="label">实付金额</text>
        <text class="value">¥{{order.actualAmount}}</text>
      </view>
    </view>

    <!-- 备注 -->
    <view wx:if="{{order.remark}}" class="order-remark">
      <text class="label">备注</text>
      <text class="remark-text">{{order.remark}}</text>
    </view>

    <!-- 提示信息 -->
    <view class="order-tips">
      <text class="tip-title">温馨提示</text>
      <text class="tip-text">订单确定后不可取消</text>
      <text class="tip-text">如需取消请联系管理员</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view wx:if="{{!loading && order}}" class="bottom-bar">
    <!-- 评价按钮（订单完成后显示，且未全部评价） -->
    <view wx:if="{{order.status === 'COMPLETED' && !hasAllReviewed}}" class="review-order-btn" bindtap="openReviewPanel">
      <text>评价菜品</text>
    </view>
    <!-- 删除订单按钮 -->
    <view wx:if="{{canEdit}}" class="delete-order-btn" bindtap="deleteOrder">
      <text>删除订单</text>
    </view>
    <view class="home-btn" bindtap="goToHome">
      <text>返回首页</text>
    </view>
  </view>
</view>

<!-- 评价弹窗 -->
<view wx:if="{{showReviewPanel}}" class="review-mask" bindtap="closeReviewPanel">
  <view class="review-container" catchtap="preventBubble">
    <view class="review-header">
      <text class="review-title">评价菜品</text>
      <text class="review-close" bindtap="closeReviewPanel">×</text>
    </view>

    <view class="review-items">
      <view wx:for="{{order.items}}" wx:key="id" class="review-item">
        <image class="review-item-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="review-item-info">
          <text class="review-item-name">{{item.menuItemName}}</text>
          <!-- 评分组件 -->
          <view class="rating-row">
            <view class="rating-stars">
              <view
                wx:for="{{[1,2,3,4,5]}}"
                wx:for-item="star"
                wx:key="star"
                class="star {{star <= (item.rating || 0) ? 'active' : ''}}"
                bindtap="setRating"
                data-index="{{index}}"
                data-itemid="{{item.id}}"
              >
                ★
              </view>
            </view>
            <text class="rating-text">{{item.rating || 0}}星</text>
          </view>
          <!-- 评价输入 -->
          <input
            class="review-input"
            placeholder="分享您的用餐体验..."
            bindinput="onReviewInput"
            data-itemid="{{item.id}}"
            value="{{item.comment || ''}}"
          />
        </view>
      </view>
    </view>

    <view class="review-footer">
      <view class="submit-review-btn" bindtap="submitReview">
        <text>提交评价</text>
      </view>
    </view>
  </view>
</view>
