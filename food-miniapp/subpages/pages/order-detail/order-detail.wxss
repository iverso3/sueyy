/* pages/order-detail/order-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 120rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: #999;
}

/* 订单内容 */
.order-content {
  padding: 30rpx;
}

/* 订单状态 */
.order-status {
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 管理员状态修改按钮 */
.admin-status-btn {
  background-color: #07C160;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.admin-status-btn text {
  font-size: 28rpx;
  color: #ffffff;
}

/* 订单信息 */
.order-info {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-size: 28rpx;
  color: #666;
}

.info-row .value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 菜品列表 */
.order-items {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.item:last-child {
  border-bottom: none;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.item-spec {
  margin-bottom: 10rpx;
}

.spec-text {
  font-size: 24rpx;
  color: #f97316;
  background-color: #fff7ed;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.item-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price .price {
  font-size: 26rpx;
  color: #666;
}

.item-price .subtotal {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 删除菜品按钮 */
.delete-item-btn {
  background-color: #ff4d4f;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.delete-item-btn text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 菜品评价显示 */
.item-review {
  margin-top: 10rpx;
  padding: 10rpx 0;
}

.review-stars {
  font-size: 24rpx;
  color: #f97316;
  margin-right: 10rpx;
}

.review-comment {
  font-size: 24rpx;
  color: #666;
}

/* 订单金额 */
.order-amount {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
}

.amount-row .label {
  font-size: 28rpx;
  color: #666;
}

.amount-row .value {
  font-size: 28rpx;
  color: #333;
}

.amount-row.total {
  border-top: 1rpx solid #f0f0f0;
  margin-top: 15rpx;
  padding-top: 25rpx;
}

.amount-row.total .label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.amount-row.total .value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b35;
}

/* 备注 */
.order-remark {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.order-remark .label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.remark-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 提示信息 */
.order-tips {
  background-color: #fff7e6;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 1rpx solid #ffd591;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff8c00;
  margin-bottom: 15rpx;
  display: block;
}

.tip-text {
  font-size: 26rpx;
  color: #ff8c00;
  line-height: 1.8;
  display: block;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.delete-order-btn {
  padding: 25rpx 40rpx;
  background-color: #ff4d4f;
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.home-btn {
  flex: 1;
  padding: 25rpx 40rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

/* 响应式调整 */
@media (min-width: 768px) {
  .container {
    max-width: 750px;
    margin: 0 auto;
  }
}

/* 评价弹窗 */
.review-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.review-container {
  width: 100%;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  overflow-y: auto;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  border-bottom: 1rpx solid #F3F4F6;
  position: sticky;
  top: 0;
  background: #fff;
}

.review-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}

.review-close {
  font-size: 48rpx;
  color: #9CA3AF;
  padding: 10rpx;
}

.review-items {
  padding: 30rpx 40rpx;
}

.review-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.review-item:last-child {
  border-bottom: none;
}

.review-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.review-item-info {
  flex: 1;
}

.review-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.rating-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 40rpx;
  color: #D1D5DB;
  transition: all 0.2s ease;
}

.star.active {
  color: #F97316;
}

.rating-text {
  font-size: 26rpx;
  color: #6B7280;
  margin-left: 16rpx;
}

.review-input {
  width: 100%;
  height: 80rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.review-footer {
  padding: 24rpx 40rpx 40rpx;
}

.submit-review-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
}

.review-order-btn {
  padding: 25rpx 40rpx;
  background: linear-gradient(135deg, #10B981, #34D399);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  margin-right: 20rpx;
}
