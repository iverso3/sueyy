/* pages/cart/cart.wxss - 橙色主题 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF7ED 0%, #FFEDD5 40%, #FEF3C7 100%);
  padding-bottom: 120rpx;
  position: relative;
}

/* 购物车头部 */
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 24rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF7ED 100%);
  border-bottom: 1rpx solid #FED7AA;
}

.header-left {
  display: flex;
  align-items: center;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #FDBA74;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-color: #F97316;
  position: relative;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 20rpx;
  border: 3rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg) translate(-2rpx, -2rpx);
}

.select-all-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.cart-header .title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  text-align: center;
}

.header-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.action-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
  color: var(--text-secondary);
}

/* 购物车列表 */
.cart-list {
  flex: 1;
  padding: 0 30rpx;
  background-color: transparent;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(249, 115, 22, 0.1);
  position: relative;
  transition: all 0.2s ease;
}

.cart-item:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 12rpx rgba(249, 115, 22, 0.08);
}

.item-image {
  width: 170rpx;
  height: 170rpx;
  border-radius: 16rpx;
  margin: 0 28rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.item-price {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.current-price {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-right: 20rpx;
}

.subtotal {
  display: none;
  font-size: 26rpx;
  color: #999;
}

/* 数量调整 */
.quantity-control {
  display: flex;
  align-items: center;
  width: 200rpx;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.quantity-btn.minus {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  color: #D97706;
  box-shadow: 0 2rpx 8rpx rgba(217, 119, 6, 0.15);
}

.quantity-btn.plus {
  background: linear-gradient(135deg, #F97316, #FB923C);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.35);
}

.quantity-btn:active {
  transform: scale(0.92);
}

.quantity {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FEE2E2, #FECACA);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn image {
  width: 32rpx;
  height: 32rpx;
}

/* 空购物车 */
.empty-cart {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-cart image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #92400E;
  margin-bottom: 50rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
}

.go-to-menu {
  padding: 24rpx 70rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  transition: all 0.2s ease;
}

.go-to-menu:active {
  transform: scale(0.98);
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: #D97706;
}

/* 购物车底部 */
.cart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  background: linear-gradient(180deg, #FFF7ED 0%, #FFFFFF 100%);
  border-top: 1rpx solid #FED7AA;
}

.footer-left {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #92400E;
  margin-right: 16rpx;
}

.total-price {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-right: 24rpx;
}

.total-quantity {
  font-size: 26rpx;
  color: #D97706;
}

.footer-right {
  flex-shrink: 0;
}

.checkout-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #F97316, #FB923C);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  min-width: 200rpx;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  transition: all 0.2s ease;
}

.checkout-btn:active {
  transform: scale(0.98);
}

.checkout-btn.delete-mode {
  background: linear-gradient(135deg, #EF4444, #F87171);
}

.checkout-btn.disabled {
  background: linear-gradient(135deg, #CBD5E1, #E2E8F0);
}

/* 选中信息 */
.selected-info {
  display: flex;
  align-items: baseline;
}

.selected-count {
  font-size: 28rpx;
  color: #92400E;
  margin-right: 24rpx;
}

.selected-price {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary-color);
}
