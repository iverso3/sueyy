<!--pages/cart/cart.wxml-->
<view class="container {{cartItems.length === 0 && !loading ? 'container-empty' : ''}}">
  <!-- 想吃列表头部 -->
  <view class="cart-header">
    <view class="header-left">
      <!-- 全选复选框 -->
      <view class="checkbox-wrapper" bindtap="toggleSelectAll" wx:if="{{cartItems.length > 0}}">
        <view class="checkbox {{selectAll ? 'checked' : ''}}"></view>
        <text class="select-all-text">全选</text>
      </view>
    </view>
    <text class="title">想吃列表</text>
    <view class="header-actions">
      <view wx:if="{{!editing}}" class="action-btn" bindtap="toggleEdit">
        <text class="action-icon">✎</text>
        <text>编辑</text>
      </view>
      <view wx:if="{{editing}}" class="action-btn" bindtap="toggleEdit">
        <text class="action-icon">✓</text>
        <text>完成</text>
      </view>
    </view>
  </view>

  <!-- 想吃商品列表 -->
  <scroll-view class="cart-list" scroll-y="true">
    <view wx:for="{{cartItems}}" wx:key="id" class="cart-item">
      <!-- 复选框 -->
      <view class="checkbox-wrapper" bindtap="toggleSelect" data-id="{{item.id}}">
        <view class="checkbox {{item.selected ? 'checked' : ''}}"></view>
      </view>

      <!-- 商品图片 -->
      <image class="item-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true" />

      <!-- 商品信息 -->
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <view class="item-price">
          <text class="current-price">¥{{item.price}}</text>
        </view>

        <!-- 数量调整 -->
        <view class="quantity-control">
          <view class="quantity-btn minus" bindtap="updateQuantity" data-id="{{item.id}}" data-type="decrease">−</view>
          <text class="quantity">{{item.quantity}}</text>
          <view class="quantity-btn plus" bindtap="updateQuantity" data-id="{{item.id}}" data-type="increase">+</view>
        </view>
      </view>

      <!-- 删除按钮（编辑模式显示） -->
      <view wx:if="{{editing}}" class="delete-btn" bindtap="deleteItem" data-id="{{item.id}}">
        <image src="/images/icon/trash.png" mode="aspectFit" />
      </view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <!-- 空想吃列表（放在scroll-view外部以实现居中） -->
  <view wx:if="{{cartItems.length === 0 && !loading}}" class="empty-cart">
    <image src="/images/empty-cart.png" mode="aspectFit" />
    <text class="empty-text">想吃列表空空如也</text>
    <view class="go-to-menu" bindtap="goToMenu">
      <text>去点餐</text>
    </view>
  </view>

  <!-- 想吃列表底部 -->
  <view wx:if="{{cartItems.length > 0}}" class="cart-footer">
    <view class="footer-left">
      <view class="selected-info">
        <text class="selected-count">已选{{selectedCount}}件</text>
        <text class="selected-price">¥{{selectedPrice}}</text>
      </view>
    </view>
    <view class="footer-right">
      <view wx:if="{{!editing}}" class="checkout-btn {{selectedCount === 0 ? 'disabled' : ''}}" bindtap="goToOrder">
        <text>去结算</text>
      </view>
      <view wx:if="{{editing}}" class="checkout-btn delete-mode" bindtap="clearCart">
        <text>清空</text>
      </view>
    </view>
  </view>
</view>

<!-- 取餐时间选择弹窗 -->
<view wx:if="{{showTimePicker}}" class="time-picker-mask" bindtap="hidePickupTimePicker">
  <view class="time-picker-container" catchtap="preventBubble">
    <view class="time-picker-header">
      <text class="time-picker-title">选择取餐时间</text>
      <text class="time-picker-subtitle">请选择您期望的取餐时间</text>
    </view>

    <view class="time-picker-content">
      <view class="selected-time-display">
        <text class="selected-time-label">取餐时间</text>
        <text class="selected-time-value">{{selectedTime}}</text>
      </view>

      <picker-view
        class="time-picker-view"
        value="{{selectedTimeIndex}}"
        bindchange="onTimeSelect"
      >
        <picker-view-column>
          <view
            wx:for="{{timeSlots}}"
            wx:key="index"
            class="time-slot-item {{item.disabled ? 'disabled' : ''}}"
          >
            {{item.label}}
          </view>
        </picker-view-column>
      </picker-view>
    </view>

    <view class="time-picker-footer">
      <view class="cancel-btn" bindtap="hidePickupTimePicker">
        <text>取消</text>
      </view>
      <view class="confirm-btn" bindtap="confirmPickupTime">
        <text>确认下单</text>
      </view>
    </view>
  </view>
</view>
