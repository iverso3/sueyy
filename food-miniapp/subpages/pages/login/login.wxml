<!--pages/login/login.wxml-->
<view class="container">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="sun-glow"></view>
  </view>

  <!-- 主内容 -->
  <view class="main-content">
    <!-- Logo区域 - 动图在上，文字在下，居中 -->
    <view class="logo-section">
      <view class="logo-wrapper">
        <image class="logo-image" src="/images/logo.gif" mode="aspectFit" />
      </view>
      <view class="brand-text">
        <text class="brand-name">家庭餐厅</text>
        <text class="brand-slogan">爱你每一天 · 暖心暖胃</text>
      </view>
    </view>

    <!-- 登录卡片 -->
    <view class="login-card">
      <!-- 协议勾选框 -->
      <view class="agreement-check">
        <view class="checkbox-wrapper" bindtap="toggleAgreement">
          <view class="checkbox {{isAgreed ? 'checked' : ''}}">
            <text wx:if="{{isAgreed}}" class="checkbox-icon">✓</text>
          </view>
          <text class="agreement-text">
            我已阅读并同意 <text class="link" catchtap="showUserAgreement">《用户协议》</text> 和 <text class="link" catchtap="showPrivacyPolicy">《隐私政策》</text>
          </text>
        </view>
      </view>

      <button
        class="btn-login {{isAgreed ? '' : 'btn-disabled'}}"
        bindtap="handleWeChatLogin"
        loading="{{isLoading}}"
        disabled="{{isLoading || !isAgreed}}"
      >
        <text class="btn-text">微信一键登录</text>
      </button>

      <view class="agreement-hint" wx:if="{{!isAgreed}}">
        请先阅读并同意用户协议和隐私政策
      </view>
    </view>

    <!-- 特色展示 -->
    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">★</text>
        <text class="feature-text">招牌菜品</text>
      </view>
      <view class="feature-divider"></view>
      <view class="feature-item">
        <text class="feature-icon">★</text>
        <text class="feature-text">闪电配送</text>
      </view>
      <view class="feature-divider"></view>
      <view class="feature-item">
        <text class="feature-icon">★</text>
        <text class="feature-text">新人专享</text>
      </view>
    </view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{errorMsg}}" class="error-toast">
    {{errorMsg}}
  </view>
</view>
