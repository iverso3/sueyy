/* ====================
   全局样式 - 餐饮小程序设计系统
   ==================== */

/* 主题色 */
page {
  --primary-color: #F97316;
  --primary-gradient: linear-gradient(135deg, #F97316, #FB923C);
  --primary-light: #FFEDD5;
  --primary-dark: #EA580C;

  --secondary-color: #2563EB;
  --secondary-gradient: linear-gradient(135deg, #2563EB, #3B82F6);

  --background-color: #F8FAFC;
  --surface-color: #FFFFFF;

  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;

  --border-color: #E2E8F0;
  --divider-color: #F1F5F9;

  --success-color: #10B981;
  --warning-color: #F59E0B;
  --error-color: #EF4444;

  --shadow-sm: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 9999rpx;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background-color: var(--background-color);
}

/* 卡片样式 */
.card {
  background-color: var(--surface-color);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

/* 按钮样式 */
.btn-primary {
  background: var(--primary-gradient);
  color: #ffffff;
  font-weight: 600;
  border-radius: var(--radius-full);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: var(--surface-color);
  color: var(--text-primary);
  font-weight: 500;
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 价格样式 */
.price {
  color: var(--primary-color);
  font-weight: 700;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 600;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-state image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-bottom: 32rpx;
}

/* 标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 24rpx 30rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.no-more {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--divider-color);
  margin: 0 30rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: var(--radius-sm);
  background-color: var(--primary-light);
  color: var(--primary-dark);
}

.tag-hot {
  background-color: #FEE2E2;
  color: #DC2626;
}

.tag-new {
  background-color: #DCFCE7;
  color: #16A34A;
}

/* 输入框样式 */
.input {
  background-color: var(--background-color);
  border-radius: var(--radius-md);
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.input:focus {
  border-color: var(--primary-color);
  background-color: var(--surface-color);
}

.input::placeholder {
  color: var(--text-tertiary);
}
